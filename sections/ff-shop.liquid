{%- liquid
  assign tabs = section.blocks | where: 'type', 'tab'
  assign per = section.settings.products_per_tab
-%}
{% style %}
  #shopify-section-{{ section.id }} .ffs { background: {{ section.settings.bg_color }}; padding-block: var(--ff-section-y); }
  #shopify-section-{{ section.id }} .ffs__inner { box-sizing: border-box; width: 100%; max-width: var(--ff-content-max); margin: 0 auto; padding-inline: var(--ff-gutter); }
  #shopify-section-{{ section.id }} .ffs__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: clamp(24px, 5vw, 72px);
    margin-bottom: clamp(32px, 4vw, 56px);
  }
  #shopify-section-{{ section.id }} .ffs__heading {
    font-family: var(--heading-font-family); font-weight: 400;
    font-size: 40px; line-height: 1.05; margin: 0; color: rgb(var(--heading-color));
  }
  #shopify-section-{{ section.id }} .ffs__tabs { display: flex; justify-content: flex-end; gap: clamp(18px, 2vw, 36px); flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .ffs__tab {
    background: none; border: 0; cursor: pointer; padding: 6px 0;
    font-family: var(--nav-font-family); font-size: 14px; font-weight: 400; color: #9f9a94;
    border-bottom: 1.5px solid transparent; transition: color 0.2s;
  }
  #shopify-section-{{ section.id }} .ffs__tab:hover { color: #555; }
  #shopify-section-{{ section.id }} .ffs__tab.is-active { color: rgb(var(--heading-color)); font-weight: 500; border-bottom-color: rgb(var(--heading-color)); }
  #shopify-section-{{ section.id }} .ffs__panel { margin-top: 0; }
  #shopify-section-{{ section.id }} .ffs__panel[hidden] { display: none; }
  #shopify-section-{{ section.id }} .ffs__grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: clamp(18px, 1.6vw, 28px); }
  #shopify-section-{{ section.id }} .ffs-prod { text-align: left; text-decoration: none; display: block; min-width: 0; }
  #shopify-section-{{ section.id }} .ffs-prod__imgwrap { aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; padding: clamp(14px, 2vw, 28px); margin-bottom: 18px; background: #f4f1ec; }
  #shopify-section-{{ section.id }} .ffs-prod__imgwrap img { max-height: 96%; max-width: 92%; width: auto; height: auto; object-fit: contain; transition: transform 0.5s ease; }
  #shopify-section-{{ section.id }} .ffs-prod:hover .ffs-prod__imgwrap img { transform: scale(1.04); }
  #shopify-section-{{ section.id }} .ffs-prod__brand { font-family: var(--nav-font-family); font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #8a8178; margin: 0 0 7px; }
  #shopify-section-{{ section.id }} .ffs-prod__name { font-family: var(--heading-font-family); font-size: 18px; font-weight: 400; line-height: 1.2; color: rgb(var(--heading-color)); margin: 0 0 6px; }
  #shopify-section-{{ section.id }} .ffs-prod__price { font-family: var(--base-font-family); font-size: 13px; color: #6b6b6b; }
  #shopify-section-{{ section.id }} .ffs__footer { border-top: 1px solid rgba(0,0,0,0.1); margin-top: 48px; padding-top: 24px; text-align: center; }
  #shopify-section-{{ section.id }} .ffs__shopall { font-family: var(--nav-font-family); font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgb(var(--heading-color)); text-decoration: none; }
  #shopify-section-{{ section.id }} .ffs__shopall:hover { opacity: 0.6; }
  #shopify-section-{{ section.id }} .ffs__empty { grid-column: 1 / -1; text-align: center; color: #8a8178; font-family: var(--base-font-family); }
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .ffs__head { display: block; text-align: center; }
    #shopify-section-{{ section.id }} .ffs__heading { margin-bottom: 24px; }
    #shopify-section-{{ section.id }} .ffs__tabs { justify-content: center; }
    #shopify-section-{{ section.id }} .ffs__grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
  }
  @media (min-width: 901px) {
    #shopify-section-{{ section.id }} .ffs__heading { font-size: 48px; }
    #shopify-section-{{ section.id }} .ffs-prod__name { font-size: 20px; }
  }
  @media (min-width: 1440px) {
    #shopify-section-{{ section.id }} .ffs__heading { font-size: 54px; }
    #shopify-section-{{ section.id }} .ffs-prod__name { font-size: 22px; }
    #shopify-section-{{ section.id }} .ffs__grid { gap: 32px; }
  }
  @media (max-width: 480px) { #shopify-section-{{ section.id }} .ffs__grid { grid-template-columns: repeat(2, minmax(0,1fr)); gap: 28px 16px; } #shopify-section-{{ section.id }} .ffs__tabs { gap: 20px; } }
{% endstyle %}

<div class="ffs">
  <div class="ffs__inner">
    <div class="ffs__head">
      {%- if section.settings.heading != blank -%}<h2 class="ffs__heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if tabs.size > 0 -%}
        <div class="ffs__tabs" role="tablist">
          {%- for block in tabs -%}
            <button type="button" class="ffs__tab{% if forloop.first %} is-active{% endif %}" role="tab" data-ffs-tab="{{ block.id }}" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- for block in tabs -%}
      {%- assign coll = block.settings.collection -%}
      <div class="ffs__panel" data-ffs-panel="{{ block.id }}" {% unless forloop.first %}hidden{% endunless %}>
        <div class="ffs__grid">
          {%- for product in coll.products limit: per -%}
            <a class="ffs-prod" href="{{ product.url }}">
              <div class="ffs-prod__imgwrap">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy" width="300" height="300">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              {%- assign ptype = product.type | default: product.vendor -%}
              {%- if ptype != blank -%}<p class="ffs-prod__brand">{{ ptype | escape }}</p>{%- endif -%}
              <p class="ffs-prod__name">{{ product.title | escape }}</p>
              <p class="ffs-prod__price">{{ product.price | money }}</p>
            </a>
          {%- else -%}
            <p class="ffs__empty">No products in this collection yet.</p>
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}

    {%- if section.settings.shop_all_label != blank -%}
      <div class="ffs__footer">
        <a class="ffs__shopall" href="{{ section.settings.shop_all_link | default: '#' }}">{{ section.settings.shop_all_label | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var tabs = root.querySelectorAll('[data-ffs-tab]');
    var panels = root.querySelectorAll('[data-ffs-panel]');
    tabs.forEach(function (t) {
      t.addEventListener('click', function () {
        var id = t.getAttribute('data-ffs-tab');
        tabs.forEach(function (x) { var on = x === t; x.classList.toggle('is-active', on); x.setAttribute('aria-selected', on ? 'true' : 'false'); });
        panels.forEach(function (p) { p.hidden = p.getAttribute('data-ffs-panel') !== id; });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FF Shop",
  "class": "section-ff-shop",
  "disabled_on": { "groups": ["aside"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Keep The Glow Going." },
    { "type": "range", "id": "products_per_tab", "min": 2, "max": 8, "step": 1, "label": "Products per tab", "default": 4 },
    { "type": "text", "id": "shop_all_label", "label": "Shop-all label", "default": "Shop All →" },
    { "type": "url", "id": "shop_all_link", "label": "Shop-all link" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FFFFFF" }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Category tab",
      "settings": [
        { "type": "text", "id": "label", "label": "Tab label", "default": "Best Sellers" },
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "FF Shop", "category": "Face Foundrié", "blocks": [ { "type": "tab" }, { "type": "tab" }, { "type": "tab" } ] }
  ]
}
{% endschema %}
