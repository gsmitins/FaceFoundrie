{%- liquid
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign total = review_blocks | size
-%}

{% style %}
  #shopify-section-{{ section.id }} .fftr {
    padding: {{ section.settings.padding_top | default: 72 }}px var(--ff-gutter) {{ section.settings.padding_bottom | default: 72 }}px;
    background: {{ section.settings.bg_color | default: '#ffffff' }};
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .fftr__header {
    text-align: center;
    margin: 0 0 48px;
  }
  #shopify-section-{{ section.id }} .fftr__subheading {
    font-family: var(--nav-font-family);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: {{ section.settings.text_color | default: '#1a1a1a' }};
    opacity: 0.5;
    margin: 0 0 16px;
  }
  #shopify-section-{{ section.id }} .fftr__heading {
    font-family: var(--heading-font-family);
    font-weight: 400;
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: {{ section.settings.text_color | default: '#1a1a1a' }};
    margin: 0;
  }
  #shopify-section-{{ section.id }} .fftr__copy {
    font-family: var(--base-font-family);
    font-size: 16px;
    line-height: 1.6;
    color: {{ section.settings.text_color | default: '#1a1a1a' }};
    opacity: 0.7;
    margin: 18px 0 0;
    max-width: 560px;
    margin-inline: auto;
  }
  #shopify-section-{{ section.id }} .fftr__copy p { margin: 0; }
  #shopify-section-{{ section.id }} .fftr__cta {
    display: inline-block;
    margin-top: 24px;
    font-family: var(--nav-font-family);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.text_color | default: '#1a1a1a' }};
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 3px;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ section.id }} .fftr__cta:hover { opacity: 0.5; }
  @media (max-width: 639px) {
    #shopify-section-{{ section.id }} .fftr__header { margin-bottom: 32px; }
  }
  #shopify-section-{{ section.id }} .fftr__track-wrap {
    overflow: hidden;
    margin: 0 calc(-1 * var(--ff-gutter));
    padding: 0 var(--ff-gutter);
  }
  #shopify-section-{{ section.id }} .fftr__track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    align-items: stretch;
  }
  #shopify-section-{{ section.id }} .fftr__card {
    flex: 0 0 calc((100% - 48px) / 3);
    background: #fff;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.07);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  #shopify-section-{{ section.id }} .fftr__card-img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
    background: #f0ece8;
  }
  #shopify-section-{{ section.id }} .fftr__card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  #shopify-section-{{ section.id }} .fftr__card-body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  #shopify-section-{{ section.id }} .fftr__card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  #shopify-section-{{ section.id }} .fftr__author {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--base-font-family);
    font-size: 14px;
    color: #1a1a1a;
    font-weight: 500;
  }
  #shopify-section-{{ section.id }} .fftr__flag {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .fftr__verified {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--base-font-family);
    font-size: 12px;
    color: #4a4a4a;
    background: #f4f4f4;
    border-radius: 30px;
    padding: 4px 10px 4px 8px;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .fftr__check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    background: #5a8f72;
    border-radius: 50%;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .fftr__check svg {
    display: block;
  }
  #shopify-section-{{ section.id }} .fftr__review-title {
    font-family: var(--base-font-family);
    font-size: 17px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 10px;
    line-height: 1.3;
  }
  #shopify-section-{{ section.id }} .fftr__review-text {
    font-family: var(--base-font-family);
    font-size: 14px;
    line-height: 1.6;
    color: #4a4a4a;
    margin: 0;
    flex: 1;
  }
  #shopify-section-{{ section.id }} .fftr__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 32px;
  }
  #shopify-section-{{ section.id }} .fftr__nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #d0d0d0;
    background: #fff;
    color: #1a1a1a;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    flex-shrink: 0;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .fftr__nav-btn:hover {
    border-color: #1a1a1a;
    background: #f5f5f5;
  }
  #shopify-section-{{ section.id }} .fftr__nav-btn:disabled {
    opacity: 0.3;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .fftr__nav-btn svg {
    display: block;
    width: 16px;
    height: 16px;
  }
  #shopify-section-{{ section.id }} .fftr__pagination {
    font-family: var(--base-font-family);
    font-size: 15px;
    color: #1a1a1a;
    min-width: 48px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .fftr__pagination strong {
    font-weight: 600;
  }

  @media (max-width: 991px) {
    #shopify-section-{{ section.id }} .fftr__card {
      flex-basis: calc((100% - 24px) / 2);
    }
  }
  @media (max-width: 639px) {
    #shopify-section-{{ section.id }} .fftr__card {
      flex-basis: 85vw;
    }
  }
{% endstyle %}

<div class="fftr" id="fftr-{{ section.id }}">
  {%- if section.settings.subheading != blank or section.settings.heading != blank or section.settings.copy != blank or section.settings.cta_label != blank -%}
    <div class="fftr__header">
      {%- if section.settings.subheading != blank -%}
        <p class="fftr__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="fftr__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.copy != blank -%}
        <div class="fftr__copy">{{ section.settings.copy }}</div>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a class="fftr__cta" href="{{ section.settings.cta_link | default: '#' }}"{% if section.settings.cta_new_tab %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta_label | escape }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="fftr__track-wrap">
    <div class="fftr__track" id="fftr-track-{{ section.id }}">
      {%- for block in review_blocks -%}
        <div class="fftr__card" {{ block.shopify_attributes }}>
          <div class="fftr__card-img-wrap">
            {%- if block.settings.before_after_image != blank -%}
              <img
                src="{{ block.settings.before_after_image | image_url: width: 900 }}"
                srcset="{{ block.settings.before_after_image | image_url: width: 450 }} 450w, {{ block.settings.before_after_image | image_url: width: 900 }} 900w, {{ block.settings.before_after_image | image_url: width: 1200 }} 1200w"
                sizes="(min-width: 992px) 33vw, (min-width: 640px) 50vw, 90vw"
                alt="{{ block.settings.before_after_image.alt | default: block.settings.author | escape }}"
                class="fftr__card-img"
                width="{{ block.settings.before_after_image.width }}"
                height="{{ block.settings.before_after_image.height }}"
                loading="lazy"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: class: 'fftr__card-img' }}
            {%- endif -%}
          </div>

          <div class="fftr__card-body">
            <div class="fftr__card-meta">
              <div class="fftr__author">
                {%- if block.settings.flag_image != blank -%}
                  <img
                    src="{{ block.settings.flag_image | image_url: width: 44 }}"
                    alt=""
                    class="fftr__flag"
                    width="22"
                    height="22"
                    loading="lazy"
                  >
                {%- endif -%}
                {{ block.settings.author | escape }}
              </div>
              <div class="fftr__verified">
                <span class="fftr__check">
                  <svg width="9" height="7" viewBox="0 0 9 7" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M1 3.5L3.5 6L8 1" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                Verified customer
              </div>
            </div>

            {%- if block.settings.review_title != blank -%}
              <h3 class="fftr__review-title">{{ block.settings.review_title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.review_text != blank -%}
              <p class="fftr__review-text">{{ block.settings.review_text | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- if total > 1 -%}
    <div class="fftr__nav">
      <button class="fftr__nav-btn" id="fftr-prev-{{ section.id }}" aria-label="Previous" disabled>
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="fftr__pagination" id="fftr-pag-{{ section.id }}">
        <strong>1</strong> / <span>{{ total }}</span>
      </div>
      <button class="fftr__nav-btn" id="fftr-next-{{ section.id }}" aria-label="Next">
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  {%- endif -%}
</div>

<script>
(function() {
  var sectionId = {{ section.id | json }};
  var track = document.getElementById('fftr-track-' + sectionId);
  var prevBtn = document.getElementById('fftr-prev-' + sectionId);
  var nextBtn = document.getElementById('fftr-next-' + sectionId);
  var pagEl = document.getElementById('fftr-pag-' + sectionId);

  if (!track || !prevBtn || !nextBtn) return;

  var index = 0;
  var cards = track.querySelectorAll('.fftr__card');
  var total = cards.length;

  function getSlidesPerView() {
    if (window.innerWidth >= 992) return 3;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }

  function maxIndex() {
    return Math.max(0, total - getSlidesPerView());
  }

  function update() {
    var spv = getSlidesPerView();
    var gap = 24;
    var cardW = cards[0] ? cards[0].offsetWidth : 0;
    var offset = index * (cardW + gap);
    track.style.transform = 'translateX(-' + offset + 'px)';

    prevBtn.disabled = index === 0;
    nextBtn.disabled = index >= maxIndex();

    if (pagEl) {
      pagEl.querySelector('strong').textContent = index + 1;
      var totalPages = maxIndex() + 1;
      pagEl.querySelector('span').textContent = totalPages;
    }
  }

  prevBtn.addEventListener('click', function() {
    if (index > 0) { index--; update(); }
  });

  nextBtn.addEventListener('click', function() {
    if (index < maxIndex()) { index++; update(); }
  });

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      index = Math.min(index, maxIndex());
      update();
    }, 120);
  });

  update();
})();
</script>

{% schema %}
{
  "name": "Trusted Reviews",
  "class": "section-ff-trusted-reviews",
  "disabled_on": {
    "groups": ["aside"]
  },
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (eyebrow)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Results you'll see with your own eyes"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Body copy"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "checkbox",
      "id": "cta_new_tab",
      "label": "Open CTA in new tab",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_after_image",
          "label": "Before / After image",
          "info": "Recommended: side-by-side before/after shot"
        },
        {
          "type": "image_picker",
          "id": "flag_image",
          "label": "Country flag image"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Customer Name"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review headline",
          "default": "Amazing results!"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Share your customer's experience here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trusted Reviews",
      "category": "Social proof",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
