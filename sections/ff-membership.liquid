{%- liquid
  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign heading_words = section.settings.heading | split: ' '
  assign heading_word_count = heading_words | size
-%}

{% style %}
  #shopify-section-{{ section.id }} .ffm {
    --ffm-min-height: {{ section.settings.min_height_desktop | default: 820 }}px;
    --ffm-mobile-image-height: {{ section.settings.mobile_image_height | default: 360 }}px;
    --ffm-content-max: {{ section.settings.content_max_width | default: 620 }}px;
    --ffm-padding-y: {{ section.settings.content_padding_y | default: 88 }}px;
    --ffm-padding-x: {{ section.settings.content_padding_x | default: 72 }}px;
    --ffm-mobile-padding-y: {{ section.settings.mobile_padding_y | default: 56 }}px;
    --ffm-mobile-padding-x: {{ section.settings.mobile_padding_x | default: 28 }}px;
    --ffm-eyebrow-size: {{ section.settings.eyebrow_size | default: 11 }}px;
    --ffm-heading-size: {{ section.settings.heading_size | default: 96 }}px;
    --ffm-heading-mobile-size: {{ section.settings.heading_size_mobile | default: 56 }}px;
    --ffm-copy-size: {{ section.settings.copy_size | default: 17 }}px;
    --ffm-feature-size: {{ section.settings.feature_size | default: 17 }}px;
    --ffm-stat-value-size: {{ section.settings.stat_value_size | default: 34 }}px;
    --ffm-stat-label-size: {{ section.settings.stat_label_size | default: 10 }}px;
    --ffm-button-size: {{ section.settings.button_size | default: 11 }}px;
    --ffm-eyebrow-gap: {{ section.settings.eyebrow_gap | default: 34 }}px;
    --ffm-divider-gap-top: {{ section.settings.divider_gap_top | default: 42 }}px;
    --ffm-divider-gap-bottom: {{ section.settings.divider_gap_bottom | default: 34 }}px;
    --ffm-feature-gap-top: {{ section.settings.feature_gap_top | default: 42 }}px;
    --ffm-stat-gap-top: {{ section.settings.stat_gap_top | default: 42 }}px;
    --ffm-button-gap-top: {{ section.settings.button_gap_top | default: 46 }}px;
    --ffm-feature-row-height: {{ section.settings.feature_row_height | default: 56 }}px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    background: linear-gradient(90deg, #223128 0%, #30433A 30%, #485548 50%, #30433A 70%, #223128 100%);
    min-height: var(--ffm-min-height);
  }
  #shopify-section-{{ section.id }} .ffm__img-col { min-height: inherit; padding: 0; }
  #shopify-section-{{ section.id }} .ffm__frame {
    position: relative; width: 100%; height: 100%; overflow: hidden;
  }
  #shopify-section-{{ section.id }} .ffm__frame img {
    width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block;
    filter: saturate(0.85) brightness(1.02);
  }
  #shopify-section-{{ section.id }} .ffm__frame .placeholder-svg { width:100%; height:100%; }
  #shopify-section-{{ section.id }} .ffm__content {
    display: flex; flex-direction: column; justify-content: center;
    padding: var(--ffm-padding-y) var(--ffm-padding-x); position: relative;
    border-left: 1px solid rgba(242,236,226,0.1);
  }
  #shopify-section-{{ section.id }} .ffm__content-inner {
    max-width: var(--ffm-content-max);
    width: 100%;
  }
  #shopify-section-{{ section.id }} .ffm__eyebrow {
    font-family: var(--nav-font-family);
    font-size: var(--ffm-eyebrow-size);
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(242,236,226,0.44);
    margin: 0 0 var(--ffm-eyebrow-gap);
  }
  #shopify-section-{{ section.id }} .ffm__heading {
    font-family: var(--heading-font-family);
    font-weight: 400;
    font-size: var(--ffm-heading-size);
    line-height: 0.9;
    letter-spacing: 0;
    color: #F2ECE2;
    margin: 0;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .ffm__heading-line {
    display: block;
  }
  #shopify-section-{{ section.id }} .ffm__divider {
    display: block;
    width: 100%;
    height: 1px;
    background: rgba(242,236,226,0.14);
    margin: var(--ffm-divider-gap-top) 0 var(--ffm-divider-gap-bottom);
  }
  #shopify-section-{{ section.id }} .ffm__copy-wrap { max-width: 520px; }
  #shopify-section-{{ section.id }} .ffm__copy-wrap p {
    font-family: var(--base-font-family);
    font-size: var(--ffm-copy-size); font-weight: 300; line-height: 1.65; color: rgba(216,209,197,0.82); margin: 0 0 16px;
  }
  #shopify-section-{{ section.id }} .ffm__features {
    max-width: 620px;
    list-style: none;
    margin: var(--ffm-feature-gap-top) 0 0;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .ffm__feature {
    display: flex;
    align-items: center;
    gap: 18px;
    min-height: var(--ffm-feature-row-height);
    border-bottom: 1px solid rgba(242,236,226,0.1);
    font-family: var(--base-font-family);
    font-size: var(--ffm-feature-size);
    font-weight: 400;
    line-height: 1.35;
    color: rgba(242,236,226,0.82);
  }
  #shopify-section-{{ section.id }} .ffm__feature:first-child {
    border-top: 1px solid rgba(242,236,226,0.1);
  }
  #shopify-section-{{ section.id }} .ffm__feature::before {
    content: "+";
    flex: 0 0 auto;
    color: rgba(242,236,226,0.56);
    font-family: var(--nav-font-family);
    font-size: 13px;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .ffm__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(28px, 4vw, 62px);
    margin-top: var(--ffm-stat-gap-top);
  }
  #shopify-section-{{ section.id }} .ffm-stat {
    min-width: 90px;
  }
  #shopify-section-{{ section.id }} .ffm-stat__value {
    display: block;
    font-family: var(--heading-font-family);
    font-size: var(--ffm-stat-value-size);
    font-weight: 400;
    line-height: 0.95;
    color: #F2ECE2;
  }
  #shopify-section-{{ section.id }} .ffm-stat__label {
    display: block;
    margin-top: 9px;
    font-family: var(--nav-font-family);
    font-size: var(--ffm-stat-label-size);
    font-weight: 700;
    letter-spacing: 0.2em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgba(242,236,226,0.5);
  }
  #shopify-section-{{ section.id }} .ffm__btn {
    display: inline-block; margin-top: var(--ffm-button-gap-top);
    font-family: var(--nav-font-family);
    font-size: var(--ffm-button-size); font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: #30433A; background: #F4EFE7; padding: 22px 58px; text-decoration: none;
    transition: opacity 0.25s; align-self: flex-start;
  }
  #shopify-section-{{ section.id }} .ffm__btn:hover { opacity: 0.88; }
  #shopify-section-{{ section.id }} .ffm__badge {
    position: absolute; bottom: clamp(28px, 3vw, 48px); right: clamp(28px, 4vw, 72px); width: clamp(82px, 7vw, 120px); height: clamp(82px, 7vw, 120px);
    opacity: 0.75; animation: ffm-spin 20s linear infinite;
  }
  @keyframes ffm-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { #shopify-section-{{ section.id }} .ffm__badge { animation: none; } }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .ffm { grid-template-columns: 1fr; min-height: 0; }
    #shopify-section-{{ section.id }} .ffm__img-col { min-height: var(--ffm-mobile-image-height); }
    #shopify-section-{{ section.id }} .ffm__content { padding: var(--ffm-mobile-padding-y) var(--ffm-mobile-padding-x); border-left: 0; }
    #shopify-section-{{ section.id }} .ffm__heading { font-size: var(--ffm-heading-mobile-size); }
    #shopify-section-{{ section.id }} .ffm__stats { gap: 24px; }
    #shopify-section-{{ section.id }} .ffm__btn { width: 100%; max-width: 320px; text-align: center; padding-inline: 28px; }
    #shopify-section-{{ section.id }} .ffm__badge { display: none; }
  }
{% endstyle %}

<div class="fully-spaced-row--medium">
  <div class="ffm">
    <div class="ffm__img-col">
      <div class="ffm__frame">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="600" height="700">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
    <div class="ffm__content">
      <div class="ffm__content-inner">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ffm__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ffm__heading">
            {%- if section.settings.stack_heading and heading_word_count >= 4 -%}
              {%- for word in heading_words -%}
                {%- if forloop.index == 1 -%}
                  <span class="ffm__heading-line">{{ word | escape }}</span>
                {%- elsif forloop.index == 2 -%}
                  <span class="ffm__heading-line">{{ word | escape }}
                {%- elsif forloop.index == 3 -%}
                  {{ word | escape }}</span>
                {%- elsif forloop.index > 3 -%}
                  {%- if forloop.index == 4 -%}<span class="ffm__heading-line">{%- endif -%}
                  {{ word | escape }}{%- unless forloop.last %} {% endunless -%}
                  {%- if forloop.last -%}</span>{%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {{ section.settings.heading | escape }}
            {%- endif -%}
          </h2>
        {%- endif -%}
        <span class="ffm__divider" aria-hidden="true"></span>
        {%- if section.settings.copy != blank -%}<div class="ffm__copy-wrap">{{ section.settings.copy }}</div>{%- endif -%}
        {%- if feature_blocks.size > 0 -%}
          <ul class="ffm__features">
            {%- for block in feature_blocks -%}
              <li class="ffm__feature" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if stat_blocks.size > 0 -%}
          <div class="ffm__stats">
            {%- for block in stat_blocks -%}
              <div class="ffm-stat" {{ block.shopify_attributes }}>
                <span class="ffm-stat__value">{{ block.settings.value | escape }}</span>
                <span class="ffm-stat__label">{{ block.settings.label | escape }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a class="ffm__btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
      </div>
      {%- if section.settings.show_badge -%}
        <svg class="ffm__badge" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs><path id="ffm-circle-{{ section.id }}" d="M 100,100 m -75,0 a 75,75 0 0,1 150,0 a 75,75 0 0,1 -150,0"/></defs>
          <text font-size="13" fill="#D8D1C5" font-family="Montserrat, sans-serif" letter-spacing="4">
            <textPath href="#ffm-circle-{{ section.id }}">· FACE FOUNDRIÉ · MEMBERSHIP ·&nbsp;&nbsp;</textPath>
          </text>
          <text x="100" y="107" text-anchor="middle" font-size="24" fill="#F2ECE2">✦</text>
        </svg>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FF Membership",
  "class": "section-ff-membership",
  "disabled_on": { "groups": ["aside"] },
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Foundrie Membership" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Skin In The Game." },
    { "type": "checkbox", "id": "stack_heading", "label": "Stack heading on separate lines", "default": true },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>Memberships designed for consistent results, exclusive savings, and expert guidance.</p><p>Your best skin isn't a one-time treatment — it's a routine.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Become a Member" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "show_badge", "label": "Show spinning badge", "default": true },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "min_height_desktop", "min": 560, "max": 1040, "step": 20, "unit": "px", "label": "Desktop minimum height", "default": 820 },
    { "type": "range", "id": "mobile_image_height", "min": 280, "max": 520, "step": 20, "unit": "px", "label": "Mobile image height", "default": 360 },
    { "type": "range", "id": "content_max_width", "min": 460, "max": 760, "step": 20, "unit": "px", "label": "Content max width", "default": 620 },
    { "type": "range", "id": "content_padding_y", "min": 48, "max": 128, "step": 4, "unit": "px", "label": "Desktop vertical padding", "default": 88 },
    { "type": "range", "id": "content_padding_x", "min": 32, "max": 120, "step": 4, "unit": "px", "label": "Desktop horizontal padding", "default": 72 },
    { "type": "range", "id": "mobile_padding_y", "min": 36, "max": 84, "step": 4, "unit": "px", "label": "Mobile vertical padding", "default": 56 },
    { "type": "range", "id": "mobile_padding_x", "min": 20, "max": 48, "step": 2, "unit": "px", "label": "Mobile horizontal padding", "default": 28 },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "eyebrow_size", "min": 9, "max": 16, "step": 1, "unit": "px", "label": "Eyebrow size", "default": 11 },
    { "type": "range", "id": "heading_size", "min": 58, "max": 132, "step": 2, "unit": "px", "label": "Desktop heading size", "default": 96 },
    { "type": "range", "id": "heading_size_mobile", "min": 38, "max": 76, "step": 2, "unit": "px", "label": "Mobile heading size", "default": 56 },
    { "type": "range", "id": "copy_size", "min": 14, "max": 20, "step": 1, "unit": "px", "label": "Copy size", "default": 17 },
    { "type": "range", "id": "feature_size", "min": 14, "max": 20, "step": 1, "unit": "px", "label": "Feature bullet size", "default": 17 },
    { "type": "range", "id": "stat_value_size", "min": 24, "max": 52, "step": 2, "unit": "px", "label": "Stat value size", "default": 34 },
    { "type": "range", "id": "stat_label_size", "min": 9, "max": 14, "step": 1, "unit": "px", "label": "Stat label size", "default": 10 },
    { "type": "range", "id": "button_size", "min": 10, "max": 14, "step": 1, "unit": "px", "label": "Button text size", "default": 11 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "eyebrow_gap", "min": 16, "max": 56, "step": 2, "unit": "px", "label": "Space after eyebrow", "default": 34 },
    { "type": "range", "id": "divider_gap_top", "min": 24, "max": 64, "step": 2, "unit": "px", "label": "Space above divider", "default": 42 },
    { "type": "range", "id": "divider_gap_bottom", "min": 20, "max": 56, "step": 2, "unit": "px", "label": "Space below divider", "default": 34 },
    { "type": "range", "id": "feature_gap_top", "min": 24, "max": 68, "step": 2, "unit": "px", "label": "Space above features", "default": 42 },
    { "type": "range", "id": "stat_gap_top", "min": 24, "max": 68, "step": 2, "unit": "px", "label": "Space above stats", "default": 42 },
    { "type": "range", "id": "button_gap_top", "min": 28, "max": 76, "step": 2, "unit": "px", "label": "Space above button", "default": 46 },
    { "type": "range", "id": "feature_row_height", "min": 44, "max": 72, "step": 2, "unit": "px", "label": "Feature row height", "default": 56 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Monthly facial included" }
      ]
    },
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "2,400+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Members" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "FF Membership",
      "category": "Face Foundrié",
      "blocks": [
        { "type": "feature" },
        { "type": "feature", "settings": { "text": "Priority booking, always" } },
        { "type": "feature", "settings": { "text": "Exclusive member pricing" } },
        { "type": "feature", "settings": { "text": "Dedicated esthetician" } },
        { "type": "stat" },
        { "type": "stat", "settings": { "value": "12", "label": "Locations" } },
        { "type": "stat", "settings": { "value": "5★", "label": "Avg rating" } }
      ]
    }
  ]
}
{% endschema %}
