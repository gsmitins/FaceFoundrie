{%- liquid
  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign heading_words = section.settings.heading | split: ' '
  assign heading_word_count = heading_words | size
-%}

{% style %}
  #shopify-section-{{ section.id }} .ffm {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    background: linear-gradient(90deg, #223128 0%, #30433A 30%, #485548 50%, #30433A 70%, #223128 100%);
    min-height: clamp(620px, 50vw, 980px);
  }
  #shopify-section-{{ section.id }} .ffm__img-col { min-height: inherit; padding: 0; }
  #shopify-section-{{ section.id }} .ffm__frame {
    position: relative; width: 100%; height: 100%; overflow: hidden;
  }
  #shopify-section-{{ section.id }} .ffm__frame img {
    width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block;
    filter: saturate(0.85) brightness(1.02);
  }
  #shopify-section-{{ section.id }} .ffm__frame .placeholder-svg { width:100%; height:100%; }
  #shopify-section-{{ section.id }} .ffm__content {
    display: flex; flex-direction: column; justify-content: center;
    padding: clamp(56px, 6vw, 112px) clamp(34px, 5vw, 96px); position: relative;
    border-left: 1px solid rgba(242,236,226,0.1);
  }
  #shopify-section-{{ section.id }} .ffm__content-inner {
    max-width: 640px;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .ffm__eyebrow {
    font-family: var(--nav-font-family);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: rgba(242,236,226,0.44);
    margin: 0 0 clamp(26px, 3vw, 46px);
  }
  #shopify-section-{{ section.id }} .ffm__heading {
    font-family: var(--heading-font-family);
    font-weight: 400;
    font-size: clamp(58px, 6.3vw, 124px);
    line-height: 0.9;
    letter-spacing: 0;
    color: #F2ECE2;
    margin: 0;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .ffm__heading-line {
    display: block;
  }
  #shopify-section-{{ section.id }} .ffm__divider {
    display: block;
    width: 100%;
    height: 1px;
    background: rgba(242,236,226,0.14);
    margin: clamp(32px, 4vw, 58px) 0 clamp(26px, 3vw, 44px);
  }
  #shopify-section-{{ section.id }} .ffm__copy-wrap { max-width: 520px; }
  #shopify-section-{{ section.id }} .ffm__copy-wrap p {
    font-family: var(--base-font-family);
    font-size: 17px; font-weight: 300; line-height: 1.65; color: rgba(216,209,197,0.82); margin: 0 0 16px;
  }
  #shopify-section-{{ section.id }} .ffm__features {
    max-width: 620px;
    list-style: none;
    margin: clamp(38px, 4vw, 64px) 0 0;
    padding: 0;
  }
  #shopify-section-{{ section.id }} .ffm__feature {
    display: flex;
    align-items: center;
    gap: 18px;
    min-height: 56px;
    border-bottom: 1px solid rgba(242,236,226,0.1);
    font-family: var(--base-font-family);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.35;
    color: rgba(242,236,226,0.82);
  }
  #shopify-section-{{ section.id }} .ffm__feature:first-child {
    border-top: 1px solid rgba(242,236,226,0.1);
  }
  #shopify-section-{{ section.id }} .ffm__feature::before {
    content: "+";
    flex: 0 0 auto;
    color: rgba(242,236,226,0.56);
    font-family: var(--nav-font-family);
    font-size: 13px;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .ffm__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(28px, 4vw, 62px);
    margin-top: clamp(38px, 4vw, 64px);
  }
  #shopify-section-{{ section.id }} .ffm-stat {
    min-width: 90px;
  }
  #shopify-section-{{ section.id }} .ffm-stat__value {
    display: block;
    font-family: var(--heading-font-family);
    font-size: clamp(30px, 2.6vw, 46px);
    font-weight: 400;
    line-height: 0.95;
    color: #F2ECE2;
  }
  #shopify-section-{{ section.id }} .ffm-stat__label {
    display: block;
    margin-top: 9px;
    font-family: var(--nav-font-family);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgba(242,236,226,0.5);
  }
  #shopify-section-{{ section.id }} .ffm__btn {
    display: inline-block; margin-top: clamp(40px, 4vw, 68px);
    font-family: var(--nav-font-family);
    font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: #30433A; background: #F4EFE7; padding: 22px 58px; text-decoration: none;
    transition: opacity 0.25s; align-self: flex-start;
  }
  #shopify-section-{{ section.id }} .ffm__btn:hover { opacity: 0.88; }
  #shopify-section-{{ section.id }} .ffm__badge {
    position: absolute; bottom: clamp(28px, 3vw, 48px); right: clamp(28px, 4vw, 72px); width: clamp(82px, 7vw, 120px); height: clamp(82px, 7vw, 120px);
    opacity: 0.75; animation: ffm-spin 20s linear infinite;
  }
  @keyframes ffm-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { #shopify-section-{{ section.id }} .ffm__badge { animation: none; } }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .ffm { grid-template-columns: 1fr; min-height: 0; }
    #shopify-section-{{ section.id }} .ffm__img-col { min-height: 360px; }
    #shopify-section-{{ section.id }} .ffm__content { padding: clamp(42px,8vw,64px) clamp(24px,7vw,40px); border-left: 0; }
    #shopify-section-{{ section.id }} .ffm__heading { font-size: clamp(46px, 14vw, 70px); }
    #shopify-section-{{ section.id }} .ffm__stats { gap: 24px; }
    #shopify-section-{{ section.id }} .ffm__btn { width: 100%; max-width: 320px; text-align: center; padding-inline: 28px; }
    #shopify-section-{{ section.id }} .ffm__badge { display: none; }
  }
  @media (min-width: 900px) {
    #shopify-section-{{ section.id }} .ffm__heading { font-size: clamp(68px, 6vw, 104px); }
  }
  @media (min-width: 1440px) {
    #shopify-section-{{ section.id }} .ffm__heading { font-size: clamp(92px, 6.4vw, 132px); }
    #shopify-section-{{ section.id }} .ffm__copy-wrap p { font-size: 19px; }
    #shopify-section-{{ section.id }} .ffm__feature { font-size: 18px; }
  }
{% endstyle %}

<div class="fully-spaced-row--medium">
  <div class="ffm">
    <div class="ffm__img-col">
      <div class="ffm__frame">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="600" height="700">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
    <div class="ffm__content">
      <div class="ffm__content-inner">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ffm__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ffm__heading">
            {%- if section.settings.stack_heading and heading_word_count >= 4 -%}
              {%- for word in heading_words -%}
                {%- if forloop.index == 1 -%}
                  <span class="ffm__heading-line">{{ word | escape }}</span>
                {%- elsif forloop.index == 2 -%}
                  <span class="ffm__heading-line">{{ word | escape }}
                {%- elsif forloop.index == 3 -%}
                  {{ word | escape }}</span>
                {%- elsif forloop.index > 3 -%}
                  {%- if forloop.index == 4 -%}<span class="ffm__heading-line">{%- endif -%}
                  {{ word | escape }}{%- unless forloop.last %} {% endunless -%}
                  {%- if forloop.last -%}</span>{%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {{ section.settings.heading | escape }}
            {%- endif -%}
          </h2>
        {%- endif -%}
        <span class="ffm__divider" aria-hidden="true"></span>
        {%- if section.settings.copy != blank -%}<div class="ffm__copy-wrap">{{ section.settings.copy }}</div>{%- endif -%}
        {%- if feature_blocks.size > 0 -%}
          <ul class="ffm__features">
            {%- for block in feature_blocks -%}
              <li class="ffm__feature" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if stat_blocks.size > 0 -%}
          <div class="ffm__stats">
            {%- for block in stat_blocks -%}
              <div class="ffm-stat" {{ block.shopify_attributes }}>
                <span class="ffm-stat__value">{{ block.settings.value | escape }}</span>
                <span class="ffm-stat__label">{{ block.settings.label | escape }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a class="ffm__btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
      </div>
      {%- if section.settings.show_badge -%}
        <svg class="ffm__badge" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs><path id="ffm-circle-{{ section.id }}" d="M 100,100 m -75,0 a 75,75 0 0,1 150,0 a 75,75 0 0,1 -150,0"/></defs>
          <text font-size="13" fill="#D8D1C5" font-family="Montserrat, sans-serif" letter-spacing="4">
            <textPath href="#ffm-circle-{{ section.id }}">· FACE FOUNDRIÉ · MEMBERSHIP ·&nbsp;&nbsp;</textPath>
          </text>
          <text x="100" y="107" text-anchor="middle" font-size="24" fill="#F2ECE2">✦</text>
        </svg>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FF Membership",
  "class": "section-ff-membership",
  "disabled_on": { "groups": ["aside"] },
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Foundrie Membership" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Skin In The Game." },
    { "type": "checkbox", "id": "stack_heading", "label": "Stack heading on separate lines", "default": true },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>Memberships designed for consistent results, exclusive savings, and expert guidance.</p><p>Your best skin isn't a one-time treatment — it's a routine.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Become a Member" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "show_badge", "label": "Show spinning badge", "default": true }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Monthly facial included" }
      ]
    },
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "2,400+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Members" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "FF Membership",
      "category": "Face Foundrié",
      "blocks": [
        { "type": "feature" },
        { "type": "feature", "settings": { "text": "Priority booking, always" } },
        { "type": "feature", "settings": { "text": "Exclusive member pricing" } },
        { "type": "feature", "settings": { "text": "Dedicated esthetician" } },
        { "type": "stat" },
        { "type": "stat", "settings": { "value": "12", "label": "Locations" } },
        { "type": "stat", "settings": { "value": "5★", "label": "Avg rating" } }
      ]
    }
  ]
}
{% endschema %}
