{%- liquid
  assign slides = section.blocks | where: 'type', 'slide'
-%}
{% style %}
  #shopify-section-{{ section.id }} .ffr {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    background: #fff;
    border-top: 1px solid rgba(0,0,0,0.07);
    border-bottom: 1px solid rgba(0,0,0,0.18);
    min-height: clamp(520px, 44vw, 760px);
  }
  #shopify-section-{{ section.id }} .ffr__content {
    display: flex; align-items: center;
    padding: var(--ff-section-y-tight) var(--ff-gutter);
  }
  #shopify-section-{{ section.id }} .ffr__inner { max-width: 520px; }
  #shopify-section-{{ section.id }} .ffr__logos { display: flex; align-items: center; gap: 14px; margin: 0 0 30px; }
  #shopify-section-{{ section.id }} .ffr__logo-ff { height: 19px; width: auto; display: block; }
  #shopify-section-{{ section.id }} .ffr__logo-x { font-size: 16px; color: #111; line-height: 1; }
  #shopify-section-{{ section.id }} .ffr__logo-rini { height: 22px; width: auto; display: block; }
  #shopify-section-{{ section.id }} .ffr__heading {
    font-family: var(--heading-font-family); font-weight: 400;
    font-size: 42px; line-height: 1.05; letter-spacing: -0.01em; color: #1a1a1a; margin: 0 0 22px;
  }
  #shopify-section-{{ section.id }} .ffr__copy {
    font-family: var(--base-font-family);
    font-size: 16px; line-height: 1.6; color: #383838; margin: 0 0 40px;
  }
  #shopify-section-{{ section.id }} .ffr__cta {
    font-family: var(--nav-font-family);
    font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: #2a2a2a; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 3px;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ section.id }} .ffr__cta:hover { opacity: 0.6; }
  #shopify-section-{{ section.id }} .ffr__media { position: relative; overflow: hidden; min-height: inherit; }
  #shopify-section-{{ section.id }} .ffr__slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.6s ease; }
  #shopify-section-{{ section.id }} .ffr__slide.is-active { opacity: 1; }
  #shopify-section-{{ section.id }} .ffr__slide img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
  #shopify-section-{{ section.id }} .ffr__dots { position: absolute; bottom: 16px; left: 16px; display: flex; gap: 10px; z-index: 5; }
  #shopify-section-{{ section.id }} .ffr__dot {
    width: 9px; height: 9px; border-radius: 50%; border: 1px solid #fff; background: transparent;
    padding: 0; cursor: pointer; transition: background 0.2s;
  }
  #shopify-section-{{ section.id }} .ffr__dot.is-active { background: #fff; }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .ffr { grid-template-columns: 1fr; min-height: 0; }
    #shopify-section-{{ section.id }} .ffr__content { order: 2; }
    #shopify-section-{{ section.id }} .ffr__media { order: 1; min-height: 360px; }
  }
  @media (min-width: 900px) {
    #shopify-section-{{ section.id }} .ffr__heading { font-size: 54px; }
  }
  @media (min-width: 1440px) {
    #shopify-section-{{ section.id }} .ffr__heading { font-size: 64px; }
    #shopify-section-{{ section.id }} .ffr__copy { font-size: 17px; }
  }
{% endstyle %}

<div class="fully-spaced-row--medium">
  <div class="ffr">
    <div class="ffr__content">
      <div class="ffr__inner">
        <div class="ffr__logos">
          <img class="ffr__logo-ff" src="{{ 'ff-logo.svg' | asset_url }}" alt="Face Foundrié" width="160" height="20">
          <span class="ffr__logo-x" aria-hidden="true">×</span>
          <img class="ffr__logo-rini" src="{{ 'rini-logo.svg' | asset_url }}" alt="Rini" width="60" height="22">
        </div>
        {%- if section.settings.heading != blank -%}<h2 class="ffr__heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
        {%- if section.settings.copy != blank -%}<p class="ffr__copy">{{ section.settings.copy | escape }}</p>{%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a class="ffr__cta" href="{{ section.settings.cta_link | default: '#' }}"{% if section.settings.cta_new_tab %} target="_blank" rel="noopener"{% endif %}>{{ section.settings.cta_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>
    <div class="ffr__media" data-ffr-media>
      {%- for block in slides -%}
        <div class="ffr__slide{% if forloop.first %} is-active{% endif %}" data-ffr-slide {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.alt | escape }}" loading="lazy" width="600" height="600">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
      {%- if slides.size > 1 -%}
        <div class="ffr__dots">
          {%- for block in slides -%}
            <button class="ffr__dot{% if forloop.first %} is-active{% endif %}" type="button" data-ffr-dot aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var slides = root.querySelectorAll('[data-ffr-slide]');
    var dots = root.querySelectorAll('[data-ffr-dot]');
    if (slides.length < 2) return;
    var i = 0, timer;
    function show(n) {
      i = (n + slides.length) % slides.length;
      slides.forEach(function (s, k) { s.classList.toggle('is-active', k === i); });
      dots.forEach(function (d, k) { d.classList.toggle('is-active', k === i); });
    }
    dots.forEach(function (d, k) { d.addEventListener('click', function () { show(k); restart(); }); });
    function restart() { clearInterval(timer); timer = setInterval(function () { show(i + 1); }, 5000); }
    restart();
  })();
</script>

{% schema %}
{
  "name": "FF Rini",
  "class": "section-ff-rini",
  "disabled_on": { "groups": ["aside"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Little Faces. Healthy Habits." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Designed for curious kids and growing routines. Safe, dermatologist-tested skincare that makes self-care approachable, playful, and age-appropriate." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Explore Rini →" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "checkbox", "id": "cta_new_tab", "label": "Open CTA in new tab", "default": true }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Image slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text" }
      ]
    }
  ],
  "presets": [
    { "name": "FF Rini", "category": "Face Foundrié", "blocks": [ { "type": "slide" }, { "type": "slide" } ] }
  ]
}
{% endschema %}
