    fill: none !important;
    stroke: white !important;
}
.video-gallery__block .video-gallery__controls .mute-icon svg *:not(rect) {
    fill: white !important;
}

.video-gallery__controls .sound-icon svg * rect {
    fill: none !important;
    stroke: none;
}
.video-gallery__controls .sound-icon svg *:not(rect) {
    fill: none !important;
    stroke: white !important;
}
.video-gallery__block .video-gallery__controls .sound-icon svg *:not(rect) {
