    }
    
    .video-product-overlay__image img {
      width: 80px;
      height: auto;
    }
    
    .video-product-overlay__title {
      font-size: 13px;
    }
    
    .video-product-overlay__price-current {
      font-size: 12px;
    }
    
    .video-product-overlay__button {
      padding: 5px 12px;
      font-size: 11px;
    }
  }
</style>

<script defer>
  document.addEventListener('DOMContentLoaded', function() {
    const autoplayEnabled = {{ section.settings.autoplay_videos | json }};
    const autoRotationEnabled = {{ section.settings.enable_auto_rotation | json }};
    const rotationDuration = {{ section.settings.rotation_duration | default: 10 }} * 1000; // Convert to milliseconds
    
    let currentRotationIndex = 0;
    let rotationInterval = null;
    let restartTimeout = null;
    let isProgrammaticRotationScroll = false;
    let programmaticScrollTimeout = null;
    
    // Initialize play/pause button states based on autoplay setting
    if (autoplayEnabled || autoRotationEnabled) {
      document.querySelectorAll('.section-id-{{ section.id }} .play-btn').forEach(function(button) {
        button.querySelector('.play-icon').style.display = 'none';
        button.querySelector('.pause-icon').style.display = 'inline';
      });
    }
    
    // Auto-rotation functionality
    if (autoRotationEnabled) {
      const videoBlocks = document.querySelectorAll('.section-id-{{ section.id }} .video-gallery__block');
      const videos = Array.from(videoBlocks).map(block => block.querySelector('video')).filter(v => v);
      
      if (videos.length > 0) {
        // Stop all videos initially
        videos.forEach(video => {
          video.pause();
          video.currentTime = 0;
        });
        
        // Function to play a specific video
        function playVideoAtIndex(index) {
          // Pause all videos and remove playing state
          videos.forEach((video, i) => {
            video.pause();
            videoBlocks[i].classList.remove('video-playing');
            const playBtn = videoBlocks[i].querySelector('.play-btn');
            if (playBtn) {
              playBtn.querySelector('.play-icon').style.display = 'inline';
              playBtn.querySelector('.pause-icon').style.display = 'none';
            }
          });
          
          // Play the current video and add playing state
          if (videos[index]) {
            videos[index].currentTime = 0;
            videos[index].muted = true; // Always mute during auto-rotation
            videos[index].play();
            videoBlocks[index].classList.add('video-playing');
            
            // Update play button
            const playBtn = videoBlocks[index].querySelector('.play-btn');
            if (playBtn) {
              playBtn.querySelector('.play-icon').style.display = 'none';
              playBtn.querySelector('.pause-icon').style.display = 'inline';
            }
            
            // Update mute button to show muted state
            const muteBtn = videoBlocks[index].querySelector('.mute-btn');
            if (muteBtn) {
              muteBtn.querySelector('.sound-icon').style.display = 'none';
              muteBtn.querySelector('.mute-icon').style.display = 'inline';
            }
            
            // Scroll video horizontally into view within the wrapper (no vertical page scroll)
            if (videoBlocks[index]) {
              const wrapper = videoBlocks[index].closest('.video-gallery__wrapper');
              if (wrapper) {
                isProgrammaticRotationScroll = true;
                if (programmaticScrollTimeout) {
                  clearTimeout(programmaticScrollTimeout);
                }
                const blockLeft = videoBlocks[index].offsetLeft;
                const blockWidth = videoBlocks[index].offsetWidth;
                const wrapperWidth = wrapper.offsetWidth;
                const scrollLeft = blockLeft - (wrapperWidth / 2) + (blockWidth / 2);
                
                wrapper.scrollTo({
                  left: scrollLeft,
                  behavior: 'smooth'
                });

                programmaticScrollTimeout = setTimeout(() => {
                  isProgrammaticRotationScroll = false;
                }, 700);
              }
            }
          }
        }
        
        // Start rotation
        function startRotation() {
          // Always clear existing interval first to prevent multiple intervals
          if (rotationInterval) {
            clearInterval(rotationInterval);
            rotationInterval = null;
          }
          
          playVideoAtIndex(currentRotationIndex);
          
          rotationInterval = setInterval(() => {
            currentRotationIndex = (currentRotationIndex + 1) % videos.length;
            playVideoAtIndex(currentRotationIndex);
          }, rotationDuration);
        }
        
        // Initialize rotation
        startRotation();
        
        // Allow manual control to override rotation temporarily
        document.querySelectorAll('.section-id-{{ section.id }} .play-btn').forEach(function(button, index) {
          button.addEventListener('click', function() {
            // Clear any existing interval and timeout
            if (rotationInterval) {
              clearInterval(rotationInterval);
              rotationInterval = null;
            }
            if (restartTimeout) {
              clearTimeout(restartTimeout);
              restartTimeout = null;
            }
            
            // Restart rotation after 30 seconds of inactivity
            restartTimeout = setTimeout(() => {
              if (autoRotationEnabled) {
                currentRotationIndex = index;
                startRotation();
              }
            }, 30000);
          });
        });
      }
    }
    
    // Helper function to toggle video play/pause
    function toggleVideoPlayPause(video, videoBlock) {
      if (video.paused) {
        // Pause all other videos first
        document.querySelectorAll('.section-id-{{ section.id }} .video-gallery__block').forEach(function(block) {
          const otherVideo = block.querySelector('video');
          if (otherVideo && otherVideo !== video && !otherVideo.paused) {
            otherVideo.pause();
            block.classList.remove('video-playing');
            const otherPlayBtn = block.querySelector('.play-btn');
            if (otherPlayBtn) {
              otherPlayBtn.querySelector('.play-icon').style.display = 'inline';
              otherPlayBtn.querySelector('.pause-icon').style.display = 'none';
            }
          }
        });
        
        // Play this video
        video.play();
        videoBlock.classList.add('video-playing');
        const playBtn = videoBlock.querySelector('.play-btn');
        if (playBtn) {
          playBtn.querySelector('.play-icon').style.display = 'none';
          playBtn.querySelector('.pause-icon').style.display = 'inline';
        }
      } else {
        // Pause this video
        video.pause();
        videoBlock.classList.remove('video-playing');
        const playBtn = videoBlock.querySelector('.play-btn');
        if (playBtn) {
          playBtn.querySelector('.play-icon').style.display = 'inline';
          playBtn.querySelector('.pause-icon').style.display = 'none';
        }
      }
    }
    
    // Play/Pause functionality for buttons
    document.querySelectorAll('.section-id-{{ section.id }} .play-btn').forEach(function(button) {
      button.addEventListener('click', function(e) {
        e.stopPropagation(); // Prevent triggering video click
        const blockId = this.getAttribute('data-block-id');
        const video = document.querySelector(`.${blockId} video`);
        const videoBlock = this.closest('.video-gallery__block');
        toggleVideoPlayPause(video, videoBlock);
      });
    });
    
    // Play/Pause functionality for clicking on video itself
    document.querySelectorAll('.section-id-{{ section.id }} .video-gallery__block video').forEach(function(video) {
      video.addEventListener('click', function(e) {
        const videoBlock = this.closest('.video-gallery__block');
        toggleVideoPlayPause(video, videoBlock);
      });
    });

    // Mute/Unmute functionality
    document.querySelectorAll('.section-id-{{ section.id }} .mute-btn').forEach(function(button) {
      button.addEventListener('click', function() {
        const blockId = this.getAttribute('data-block-id');
        const video = document.querySelector(`.${blockId} video`);
        video.muted = !video.muted;
        if (video.muted) {
          this.querySelector('.sound-icon').style.display = 'none';
          this.querySelector('.mute-icon').style.display = 'inline';
        } else {
          this.querySelector('.sound-icon').style.display = 'inline';
          this.querySelector('.mute-icon').style.display = 'none';
        }
      });
    });

    // Product button functionality
    document.querySelectorAll('.section-id-{{ section.id }} .product-btn').forEach(function(button) {
      const videoBlock = button.closest('.video-gallery__block');
      button._isOverlayVisible = false; // Store state on button element
      
      if (videoBlock) {
        // Toggle overlay on click
        button.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          e.stopImmediatePropagation(); // Prevent other handlers
          
          button._isOverlayVisible = !button._isOverlayVisible;
          
          const overlay = videoBlock.querySelector('.video-product-overlay');
          if (overlay) {
            if (button._isOverlayVisible) {
              // Show overlay - mark as user controlled and remove closed state
              overlay.classList.add('video-product-overlay--user-controlled');
              overlay.classList.remove('video-product-overlay--closed');
              videoBlock.classList.add('show-product-overlay');
            } else {
              // Hide overlay - add closed state and remove user control
              overlay.classList.add('video-product-overlay--closed');
              overlay.classList.remove('video-product-overlay--user-controlled');
              videoBlock.classList.remove('show-product-overlay');
            }
          }
          
          return false;
        });
      }
    });

    // Product overlay interactions
    document.querySelectorAll('.section-id-{{ section.id }} .video-product-overlay').forEach(function(overlay) {
      const buyButton = overlay.querySelector('.video-product-overlay__button');
      const closeButton = overlay.querySelector('.video-product-overlay__close[data-video-overlay-close="true"]');
      
      // Close button functionality
      if (closeButton) {
        console.log('Setting up close button for overlay:', overlay); // Debug
        closeButton.addEventListener('click', function(e) {
          console.log('Close button clicked!'); // Debug
          // Only handle if this is specifically our close button
          if (!e.target.closest('[data-video-overlay-close="true"]')) return;
          
          e.preventDefault();
          e.stopPropagation();
          e.stopImmediatePropagation(); // Prevent any other click handlers
          
          const videoBlock = overlay.closest('.video-gallery__block');
          const productBtn = videoBlock ? videoBlock.querySelector('.product-btn') : null;
          
          console.log('Found videoBlock:', videoBlock, 'productBtn:', productBtn); // Debug
          
          if (videoBlock && productBtn) {
            // Close overlay and mark as user-closed (stays closed until explicitly opened)
            videoBlock.classList.remove('show-product-overlay');
            overlay.classList.add('video-product-overlay--closed');
            overlay.classList.remove('video-product-overlay--user-controlled');
            
            // Reset product button state
            productBtn._isOverlayVisible = false;
            productBtn.classList.remove('active');
            
            console.log('Overlay closed successfully!'); // Debug
          }
          
          // Return false to ensure no further event processing
          return false;
        }, true); // Use capture phase to intercept before other handlers
      } else {
        console.log('No close button found for overlay:', overlay); // Debug
      }
      
      if (buyButton) {
        // Add click tracking
        buyButton.addEventListener('click', function(e) {
          // You can add analytics tracking here if needed
          console.log('Product buy button clicked:', buyButton.href);
        });
        
        // Prevent video controls from interfering with product overlay
        overlay.addEventListener('click', function(e) {
          e.stopPropagation();
        });
        
        // Add hover effects for better UX
        overlay.addEventListener('mouseenter', function() {
          this.style.transform = this.classList.contains('video-product-overlay--center') 
            ? 'translate(-50%, -50%) translateY(-5px)' 
            : 'translateY(-5px)';
        });
        
        overlay.addEventListener('mouseleave', function() {
          this.style.transform = this.classList.contains('video-product-overlay--center') 
            ? 'translate(-50%, -50%) translateY(0)' 
            : 'translateY(0)';
        });
      }
    });

    // Reset closed state when scrolling (but preserve user-controlled state)
    const videoWrapper = document.querySelector('.section-id-{{ section.id }} .video-gallery__wrapper');
    if (videoWrapper) {
      let scrollTimeout;
      
      videoWrapper.addEventListener('scroll', function() {
        if (isProgrammaticRotationScroll) {
          return;
        }

        clearTimeout(scrollTimeout);
        
        // Reset closed state for overlays after scrolling
        scrollTimeout = setTimeout(() => {
          // Reset closed state only for overlays that are NOT user-controlled
          document.querySelectorAll('.section-id-{{ section.id }} .video-product-overlay.video-product-overlay--closed:not(.video-product-overlay--user-controlled)').forEach(overlay => {
            overlay.classList.remove('video-product-overlay--closed');
          });
          
          // Auto-play the centered video after scroll stops
          const wrapper = videoWrapper;
          const wrapperRect = wrapper.getBoundingClientRect();
          const wrapperCenter = wrapperRect.left + wrapperRect.width / 2;
          
          const videoBlocks = document.querySelectorAll('.section-id-{{ section.id }} .video-gallery__block');
          let closestBlock = null;
          let closestDistance = Infinity;
          
          // Find the video block closest to the center
          videoBlocks.forEach((block) => {
            const blockRect = block.getBoundingClientRect();
            const blockCenter = blockRect.left + blockRect.width / 2;
            const distance = Math.abs(blockCenter - wrapperCenter);
            
            if (distance < closestDistance) {
              closestDistance = distance;
              closestBlock = block;
            }
          });
          
          // Play the centered video if found
          if (closestBlock) {
            const video = closestBlock.querySelector('video');
            if (video) {
              // Pause all other videos
              videoBlocks.forEach((block) => {
                if (block !== closestBlock) {
                  const otherVideo = block.querySelector('video');
                  if (otherVideo && !otherVideo.paused) {
                    otherVideo.pause();
                    block.classList.remove('video-playing');
                    const playBtn = block.querySelector('.play-btn');
                    if (playBtn) {
                      playBtn.querySelector('.play-icon').style.display = 'inline';
                      playBtn.querySelector('.pause-icon').style.display = 'none';
                    }
                  }
                }
              });
              
              // Play the centered video if it's not already playing
              if (video.paused) {
                video.currentTime = 0;
                video.muted = true;
                video.play();
                closestBlock.classList.add('video-playing');
                
                const playBtn = closestBlock.querySelector('.play-btn');
                if (playBtn) {
                  playBtn.querySelector('.play-icon').style.display = 'none';
                  playBtn.querySelector('.pause-icon').style.display = 'inline';
                }
                
                const muteBtn = closestBlock.querySelector('.mute-btn');
                if (muteBtn) {
                  muteBtn.querySelector('.sound-icon').style.display = 'none';
                  muteBtn.querySelector('.mute-icon').style.display = 'inline';
                }
              }
              
              // Pause auto-rotation temporarily
              if (rotationInterval) {
                clearInterval(rotationInterval);
                rotationInterval = null;
              }
              if (restartTimeout) {
                clearTimeout(restartTimeout);
                restartTimeout = null;
              }
              
              // Restart auto-rotation after 30 seconds
              if (autoRotationEnabled) {
                restartTimeout = setTimeout(() => {
                  // Find the index of currently playing video
                  const currentIndex = Array.from(videoBlocks).indexOf(closestBlock);
                  if (currentIndex !== -1) {
                    currentRotationIndex = currentIndex;
                    startRotation();
                  }
                }, 30000);
              }
            }
          }
        }, 150); // Wait for scroll to stop
      });
    }

    // Navigation functionality
    const containers = document.querySelectorAll('.section-id-{{ section.id }} .video-gallery__container');
    containers.forEach(function(container) {
      const wrapper = container.querySelector('.video-gallery__wrapper');
      const prevBtn = container.querySelector('.video-gallery__nav--prev');
      const nextBtn = container.querySelector('.video-gallery__nav--next');
      
      if (!wrapper || !prevBtn || !nextBtn) return;
      
      const videoWidth = {{ section.settings.video_width }};
      const gap = {{ section.settings.video_gap }};
      const scrollAmount = videoWidth + gap;
      
      // Check if navigation is needed
      function checkNavigation() {
        const needsNav = wrapper.scrollWidth > wrapper.clientWidth;
        if (needsNav) {
          prevBtn.classList.add('visible');
          nextBtn.classList.add('visible');
        } else {
          prevBtn.classList.remove('visible');
          nextBtn.classList.remove('visible');
        }
      }
      
      // Initial check
      checkNavigation();
      
      // Check on resize
      window.addEventListener('resize', checkNavigation);
      
      // Navigation button events
      prevBtn.addEventListener('click', function() {
        wrapper.scrollBy({
          left: -scrollAmount,
          behavior: 'smooth'
        });
      });
      
      nextBtn.addEventListener('click', function() {
        wrapper.scrollBy({
          left: scrollAmount,
          behavior: 'smooth'
        });
      });
      
      // Update button states based on scroll position
      wrapper.addEventListener('scroll', function() {
        const maxScroll = wrapper.scrollWidth - wrapper.clientWidth;
        prevBtn.style.opacity = wrapper.scrollLeft <= 0 ? '0.5' : '1';
        nextBtn.style.opacity = wrapper.scrollLeft >= maxScroll ? '0.5' : '1';
      });
    });
  });

  // Lazy loading: Remove the src from lazy videos and load when in view
  document.addEventListener("DOMContentLoaded", function() {
    var lazyVideos = document.querySelectorAll("video.lazy-video");
    if ("IntersectionObserver" in window) {
      let videoObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            let video = entry.target;
            let dataSrc = video.getAttribute("data-src");
            if (dataSrc) {
              video.setAttribute("src", dataSrc);
            }
            video.removeAttribute("data-src");
            observer.unobserve(video);
          }
        });
      });
      lazyVideos.forEach(video => {
        // Remove src and store it in data-src for lazy loading
        let src = video.getAttribute("src");
        if (src) {
          video.setAttribute("data-src", src);
          video.removeAttribute("src");
        }
        videoObserver.observe(video);
      });
    } else {
      // Fallback: load all videos immediately
      lazyVideos.forEach(video => {
        let dataSrc = video.getAttribute("data-src");
        if (dataSrc) {
          video.setAttribute("src", dataSrc);
          video.removeAttribute("data-src");
        }
      });
    }
  });
</script>

