<section class="global-inner-padding video-gallery section-id-{{ section.id }} video-gallery--{{ section.settings.style_variant }}">

  {% if section.settings.subheading != blank %}
    <div style="display: flex; justify-content: center;" class="text-overlay__subheading subheading subheading--over lightish-spaced-row-above">
      {{ section.settings.subheading | escape }}
    </div>
  {% endif %}

  {% if section.settings.title != blank %}
    <div class="upper-wrapper-head">
      <div class="header-wrap-lp">
        <h2 class="global-header text-overlay__title for-gustavs-lp h1 Heading">{{ section.settings.title }}</h2>
      </div>
    </div>
  {% endif %}

  <div class="video-gallery__container">
    {% if section.settings.enable_navigation and section.settings.style_variant != 'social-proof' %}
      <button class="video-gallery__nav video-gallery__nav--prev" aria-label="Previous videos">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="video-gallery__nav video-gallery__nav--next" aria-label="Next videos">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {% endif %}
    
    <div class="video-gallery__wrapper video-gallery__wrapper--{{ section.settings.style_variant }}">
      {% for block in section.blocks %}
        <div class="video-gallery__block block-id-{{ block.id }}">
          {% if block.settings.video != blank %}
            {% liquid
              if block.settings.poster_image != blank
                assign poster_url = block.settings.poster_image | image_url: width: 1200
              else
                assign poster_url = block.settings.video.preview_image | image_url: width: 1200
              endif
            %}
            {{ block.settings.video | video_tag: autoplay: section.settings.autoplay_videos, controls: false, loop: true, muted: true, poster: poster_url, class: "lazy-video" }}
            
            {% if block.settings.featured_product != blank %}
              {% assign product = block.settings.featured_product %}
              <div class="video-product-overlay video-product-overlay--{{ block.settings.product_position }}" data-block-id="{{ block.id }}">
                                <button class="video-product-overlay__close" aria-label="Close product details" data-video-overlay-close="true">
                  {%- render 'icon-close' -%}
                </button>
                <div class="video-product-overlay__content">
                  {% if product.featured_image %}
                    <div class="video-product-overlay__image">
                      <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title | escape }}" width="80" height="80" loading="lazy">
                    </div>
                  {% endif %}
                  <div class="video-product-overlay__details">
                    <h4 class="video-product-overlay__title">{{ product.title | truncate: 50 }}</h4>
                    <div class="video-product-overlay__price">
                      {% if product.compare_at_price > product.price %}
                        <span class="video-product-overlay__price-compare">{{ product.compare_at_price | money }}</span>
                      {% endif %}
                      <span class="video-product-overlay__price-current">from {{ product.price | money }}</span>
                    </div>
                    <a href="{{ product.url }}" class="video-product-overlay__button">
                      {{ section.settings.overlay_button_text | default: 'View Product' }}
                    </a>
                  </div>
                </div>
              </div>
            {% endif %}
            
            {% if section.settings.style_variant == 'social-proof' %}
              {% if block.settings.overlay_title != blank or block.settings.overlay_eyebrow != blank %}
                <div class="video-gallery__proof-overlay">
                  {% if block.settings.overlay_eyebrow != blank %}
                    <p class="video-gallery__proof-eyebrow">{{ block.settings.overlay_eyebrow | escape }}</p>
                  {% endif %}
                  {% if block.settings.overlay_title != blank %}
                    <p class="video-gallery__proof-title">{{ block.settings.overlay_title | escape }}</p>
                  {% endif %}
                </div>
              {% endif %}
            {% endif %}

            <div class="video-gallery__controls video-gallery__controls--{{ section.settings.style_variant }}">
              <button class="video-gallery__btn play-btn" data-block-id="block-id-{{ block.id }}">
                <span class="play-icon">{% render 'lp-sound', icon: 'play' %}</span>
                <span class="pause-icon" style="display: none;">{% render 'lp-sound', icon: 'pause' %}</span>
              </button>
              {% if section.settings.style_variant != 'social-proof' %}
                {% if section.settings.show_mute_button or block.settings.show_mute_button %}
                  <button class="video-gallery__btn mute-btn" data-block-id="block-id-{{ block.id }}">
                    <span class="sound-icon" style="display: none;">{% render 'lp-sound', icon: 'sound' %}</span>
                    <span class="mute-icon">{% render 'lp-sound', icon: 'mute' %}</span>
                  </button>
                {% endif %}
              {% endif %}
              {% if section.settings.style_variant != 'social-proof' and block.settings.featured_product != blank and block.settings.show_product_button %}
                <button class="video-gallery__btn product-btn" data-block-id="block-id-{{ block.id }}" aria-label="Show product details">
                  {% render 'icon-bag' %}
                </button>
              {% endif %}
            </div>
          {% else %}
            <img src="{{ block.settings.poster_image | image_url }}" alt="Video Poster" width="300" height="200">
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if section.settings.button_link != blank %}
    <div class="gustavs-lp-button-wrap section-id-block-{{ section.id }}">
      <a class="gustavs-lp-button" href="{{ section.settings.button_link }}">
        {{ section.settings.button_label | escape }}
        {% if section.settings.arrow %}
          <span class="arrow-cont-button">{% render 'lp-icon-chevron-right' %}</span>
        {% endif %}
      </a>
    </div>
  {% endif %}

</section>

<style>

  
