   {% endif %}
  }
  @media (max-width: 767px) {
    .section-id-block-{{ section.id }} {
      margin-top: {{ section.settings.gap_text_mobile }}px !important; 
    }
  }
  .section-id-{{ section.id }} .upper-wrapper-head {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-direction: row;
    align-items: center;
    margin-bottom: {{ section.settings.gap_text }}px;
