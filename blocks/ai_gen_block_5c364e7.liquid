{% doc %}
  @prompt
    Create a premium services section for a facial spa called FaceFoundrie using category cards. Display 4 category cards with warm beige backgrounds and editorial typography: "Next-Level Facials", "Enhancements", "Mini Facials", and "All Things Face". Each card should be expandable (accordion or click-to-expand) to reveal the individual services listed below it. Use warm beige and cream tones, clean serif or editorial typography, and a premium spa aesthetic. Include the following services per card:
    
    - Next-Level Facials (40–50 minute results-driven facials): Microchanneling Powered by Procell, Royal Treatment, Hydrafacial, Firm AF, Clean + Natural, The Sculpt, Cryo Queen, Foundré Glow, Acne Agent (Powered by Face Reality)
    - Enhancements (add-ons to customize your facial): Dermaplaning, Chemical Peel, Skin Renewal Mask by BIOEFFECT, Enzyme Mask, Hungarian Massage, Facial Cupping, Scalp Massage, LED Light, Gua Sha, Hydrating Lip Mask, Skin Renewal Eye Mask by BIOEFFECT
    - Mini Facials (20-minute quick treatments): Mini Derma, Mini Mask
    - All Things Face (lashes, brows + waxing): Brow Wax + Shape, Brow Wax + Tint, Brow Henna, Brow Lamination, Lash Lift + Tint
    
    Each card should show the category name and subtitle by default, with a smooth expand/collapse animation to reveal the service list. Section should be fully responsive and mobile-friendly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ff-services-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.section_background }};
  }

  .ff-services__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ff-services__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ff-services__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }

  .ff-services__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ff-services__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ff-services__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ff-services__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .ff-services__card-header-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .ff-services__card-title-wrapper-{{ ai_gen_id }} {
    flex: 1;
  }

  .ff-services__card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_title_font.family }}, {{ block.settings.card_title_font.fallback_families }};
    font-weight: {{ block.settings.card_title_font.weight }};
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px 0;
    letter-spacing: 0.5px;
  }

  .ff-services__card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    margin: 0;
    line-height: 1.5;
    font-style: italic;
  }

  .ff-services__card-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ block.settings.icon_color }};
  }

  .ff-services__card-{{ ai_gen_id }}.is-expanded .ff-services__card-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ff-services__card-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
  }

  .ff-services__card-{{ ai_gen_id }}.is-expanded .ff-services__card-content-{{ ai_gen_id }} {
    max-height: 2000px;
    padding: 0 {{ block.settings.card_padding }}px {{ block.settings.card_padding }}px;
  }

  .ff-services__service-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ff-services__service-item-{{ ai_gen_id }} {
    padding: {{ block.settings.service_item_spacing }}px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
    font-size: {{ block.settings.service_text_size }}px;
    color: {{ block.settings.service_text_color }};
    line-height: 1.6;
  }

  .ff-services__service-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  @media screen and (max-width: 989px) {
    .ff-services__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ff-services__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ff-services__card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ff-services__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ff-services__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .ff-services__card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_size }}px * 0.85);
    }

    .ff-services__card-padding-{{ ai_gen_id }} {
      padding: calc({{ block.settings.card_padding }}px * 0.75);
    }
  }
{% endstyle %}

