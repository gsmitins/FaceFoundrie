<script>
  (function() {
    class FFServices{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ff-services__card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          const header = card.querySelector('.ff-services__card-header-{{ ai_gen_id }}');
          
          header.addEventListener('click', () => {
            const isExpanded = card.classList.contains('is-expanded');
            
            card.classList.toggle('is-expanded');
            header.setAttribute('aria-expanded', !isExpanded);
          });

          header.setAttribute('role', 'button');
          header.setAttribute('aria-expanded', 'false');
          header.setAttribute('tabindex', '0');

          header.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              header.click();
            }
          });
        });
      }
    }

    customElements.define('ff-services-{{ ai_gen_id }}', FFServices{{ ai_gen_id }});
  })();
</script>

